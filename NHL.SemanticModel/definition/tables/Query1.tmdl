	partition Query1 = m
		mode: import
		source = ```
				let
				    // 1. Diagnostic Test for a known player with heavy ice time (Connor McDavid)
				    PlayerID = "8478402", 
				    BaseUrl = "https://api-web.nhle.com",
				    Path = "v1/edge/skater-skating-speed-detail/" & PlayerID & "/20242025/2",
				
				    // 2. Fetch the raw JSON WITHOUT try...otherwise to expose the true payload
				    Source = Json.Document(Web.Contents(BaseUrl, [RelativePath=Path])),
				
				    // 3. Convert the Record to a Table so you can clearly read the Keys and Values
				    ConvertedToTable = try Record.ToTable(Source) otherwise Source
				in
				    ConvertedToTable
				```

