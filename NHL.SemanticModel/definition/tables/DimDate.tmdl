		annotation SummarizationSetBy = Automatic

	partition DimDate = calculated
		mode: import
		source =
				
				VAR StartDate = DATE(2024, 9, 1) -- Adjust to your earliest season data
				VAR EndDate = DATE(2026, 6, 30)   -- Adjust to your latest projected data
				RETURN
				ADDCOLUMNS (
				    CALENDAR (StartDate, EndDate),
				    "DateKey", FORMAT ( [Date], "YYYYMMDD" ),
				    "Year", YEAR ( [Date] ),
				    "Quarter", "Q" & FORMAT ( [Date], "Q" ),
				    "Month Num", MONTH ( [Date] ),
				    "Month Name", FORMAT ( [Date], "MMMM" ),
				    "Month Short", FORMAT ( [Date], "MMM" ),
				    "Week Num", WEEKNUM ( [Date] ),
				    "Day Name", FORMAT ( [Date], "dddd" ),
				    "Day of Week Num", WEEKDAY ( [Date], 2 ), -- 1 = Monday
				    "Is Weekend", IF ( WEEKDAY ( [Date], 2 ) > 5, "Weekend", "Weekday" ),
				    "Season", IF( MONTH([Date]) >= 9, YEAR([Date]) & YEAR([Date]) + 1, YEAR([Date]) - 1 & YEAR([Date]) )
				)

	annotation PBI_Id = 73169ceb921743fe99c8f2ea7ac23ba5

